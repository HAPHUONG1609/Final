PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Thay bằng chuỗi bí mật riêng khi chạy thật.
SESSION_SECRET=change-this-session-secret
SESSION_COOKIE_SECURE=false

# SQL Server local. Khi dùng Docker, các giá trị này được docker-compose.yml cấp.
SQL_SERVER=localhost\SQLEXPRESS
SQL_DATABASE=QLSV_AT
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_USER=
SQL_PASSWORD=

# Có thể dùng chuỗi kết nối đầy đủ thay cho các biến SQL phía trên.
# SQL_CONNECTION_STRING=Server=localhost\SQLEXPRESS;Database=QLSV_AT;Trusted_Connection=Yes;Driver={ODBC Driver 17 for SQL Server};Encrypt=no;TrustServerCertificate=yes

JAVA_CRYPTO_URL=http://localhost:8080

