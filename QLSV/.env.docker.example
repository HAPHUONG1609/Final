MSSQL_SA_PASSWORD=ChangeMe_StrongPass123!
SESSION_SECRET=change-this-session-secret

# EC2 public DNS/IP or your domain. Example: http://13.250.10.20
CLIENT_ORIGIN=http://localhost

# Keep this as /backend when using the provided frontend Nginx proxy.
VITE_API_URL=/backend

# Optional: set these on EC2 if seed-history must use an explicit SQL connection string.
# SQL_CONNECTION_STRING=Server=db,1433;Database=QLSV_AT;UID=sa;PWD=ChangeMe_StrongPass123!;Driver={ODBC Driver 18 for SQL Server};Encrypt=no;TrustServerCertificate=yes
# DB_CONNECTION_STRING=Server=db,1433;Database=QLSV_AT;UID=sa;PWD=ChangeMe_StrongPass123!;Driver={ODBC Driver 18 for SQL Server};Encrypt=no;TrustServerCertificate=yes

SEED_TEACHER_PIN=123456
SEED_CONCURRENCY=20
MAX_SEED_ROWS=0
PIN_REENCRYPT_CONCURRENCY=6

FRONTEND_PORT=80

# Set true only when you put HTTPS in front of the app.
SESSION_COOKIE_SECURE=false
